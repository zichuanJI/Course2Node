# Database
DATABASE_URL=postgresql+asyncpg://course2note:course2note@localhost:5432/course2note

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/artifacts

# LLM Providers
# synthesize / extract stage (flagship model)
SYNTHESIZE_LLM_PROVIDER=claude          # claude | gemini
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# retrieve stage (lightweight agent)
RETRIEVE_LLM_PROVIDER=minimax
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Embed Provider
EMBED_PROVIDER=openai                   # openai | gemini
OPENAI_API_KEY=

# Search Provider
SEARCH_PROVIDER=tavily                  # tavily | bing
TAVILY_API_KEY=
BING_SEARCH_API_KEY=
