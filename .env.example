# Storage
STORAGE_BACKEND=local
# Use an absolute path for local development if you want old sessions to survive
# different startup directories. Use /artifacts when running docker compose.
LOCAL_STORAGE_PATH=./artifacts

# Audio / ASR
WHISPER_MODEL_SIZE=base
WHISPER_LANGUAGE=auto
# Optional external faster-whisper runner. Usually not needed if faster-whisper is
# installed in backend/.venv.
# FASTER_WHISPER_PYTHON_PATH=/absolute/path/to/python
# FASTER_WHISPER_RUNNER_PATH=/absolute/path/to/faster_whisper_runner.py

# Graph LLM
GRAPH_LLM_BASE_URL=
GRAPH_LLM_API_KEY=
GRAPH_LLM_MODEL=
GRAPH_LLM_TIMEOUT_SECONDS=90
GRAPH_LLM_BATCH_MAX_CHARS=5200
GRAPH_LLM_BATCH_MAX_CHUNKS=8
GRAPH_LLM_MAX_OUTPUT_TOKENS=6000
GRAPH_LLM_STRICT=true

# Kimi PDF extraction
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_API_KEY=
KIMI_MODEL=kimi-k2.6
KIMI_TIMEOUT_SECONDS=90
KIMI_MAX_PAGES_PER_CALL=2
KIMI_MAX_OUTPUT_TOKENS=2200

# Dedicated embedding service
EMBED_PROVIDER=bge_m3
EMBEDDING_LOCAL_MODEL_NAME=BAAI/bge-m3
EMBEDDING_LOCAL_DEVICE=cpu
EMBEDDING_LOCAL_USE_FP16=false
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSIONS=1024

# Only required when EMBED_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_TIMEOUT_SECONDS=30

# Only required when EMBED_PROVIDER=openai
OPENAI_API_KEY=

# Optional frontend override. Vite reads this from frontend/.env.local.
# VITE_API_BASE_URL=http://localhost:8000
